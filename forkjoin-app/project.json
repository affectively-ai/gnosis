{
  "name": "forkjoin-app",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "open-source/gnosis/forkjoin-app/src",
  "projectType": "application",
  "tags": ["scope:edge", "scope:mcp", "scope:docs", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run build"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run dev"
      }
    },
    "deploy:dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run deploy:dev"
      },
      "dependsOn": ["build"]
    },
    "deploy:stage": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run deploy:stage"
      },
      "dependsOn": ["build"]
    },
    "deploy:prod": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run deploy:prod"
      },
      "dependsOn": ["build"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run test",
        "passWithNoTests": true
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run typecheck"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "open-source/gnosis/forkjoin-app/src/**/*.ts",
          "open-source/gnosis/forkjoin-app/client/**/*.{ts,tsx}",
          "open-source/gnosis/forkjoin-app/scripts/**/*.ts",
          "open-source/gnosis/forkjoin-app/test/**/*.ts"
        ]
      }
    },
    "smoke:deployed": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run smoke:deployed"
      }
    },
    "register-aeonpid": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun ../../../scripts/register-aeonpid.ts forkjoin-app production"
      }
    }
  }
}
