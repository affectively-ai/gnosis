// aeon_shell_rhizome.test.gg — Verification harness for Rhizome topologies
//
// Validates the Fork/Race/Collapse patterns derived from the Rhizome
// philosophy and implementation documents for aeon-shell.

(test_suite: TestSuite { name: 'aeon-shell-rhizome' })

(rhizome_metabolism: Verify { module: './aeon_shell_rhizome_metabolism.gg', beta1_max: '4' })
(rhizome_projections: Verify { module: './aeon_shell_rhizome_projections.gg', beta1_max: '4' })

(test_suite)-[:FORK]->(rhizome_metabolism | rhizome_projections)

(rhizome_metabolism)-[:RACE { expect: 'safe' }]->(metabolism_result: Result)
(rhizome_projections)-[:RACE { expect: 'safe' }]->(projections_result: Result)

(metabolism_result | projections_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)