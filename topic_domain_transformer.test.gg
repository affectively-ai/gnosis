// topic_domain_transformer.test.gg
// Formal verification topology for the canonical topic-domain neural module.

(test_suite: TestSuite { name: 'topic-domain-transformer' })
(topic_module: Verify { module: './topic_domain_transformer.gg', beta1_max: '24' })

// Fork into module verification.
(test_suite)-[:FORK]->(topic_module)

// Race module invariants (safe / bounded).
(topic_module)-[:RACE { expect: 'safe' }]->(topic_result: Result)

// Fold into final verdict.
(topic_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
