// warmup_invert_physical_biological.gg — Warm-up crosses into fatigue
//
// Inversion: the same substrate variables rise, but heat and fatigue interfere
// with readiness, so the system overshoots the efficient operating point.

(body: System { mode: 'sprinter' })
(circulation: Physiology { metric: 'blood-flow' })
(temperature: Physiology { metric: 'muscle-temp' })
(coordination: Motor { metric: 'recruitment' })
(fatigue: Physiology { metric: 'lactate' })
(readiness: Aggregate { phase: 'primed' })
(heat_debt: Debt { type: 'overwarm' })
(strained_state: State { phase: 'fatigued' })
(cooldown: Sink { medium: 'waste-heat', capacity: '1' })

(body)-[:FORK]->(circulation | temperature | coordination)
(temperature)-[:PROCESS]->(fatigue)
(circulation | temperature | coordination)-[:FOLD { strategy: 'readiness' }]->(readiness)
(temperature | fatigue)-[:INTERFERE { mode: 'destructive' }]->(heat_debt)
(readiness | heat_debt)-[:FOLD { strategy: 'subtract-fatigue' }]->(strained_state)
(strained_state)-[:PROCESS]->(performance: Output)
(strained_state)-[:VENT { condition: 'shutdown', drift_coefficient: '2', repair_debt: '0' }]->(cooldown)
