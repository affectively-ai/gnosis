// fold_heat_additive.gg — THM-FOLD-HEAT-HIERARCHY witness (sequential folds = sum of heats)
//
// Two folds applied in sequence: total heat = heat_1 + heat_2.
// First fold: 4 -> 2 (heat = log2(2) = 1 bit per merge, 2 merges = 2 bits).
// Second fold: 2 -> 1 (heat = log2(2) = 1 bit).
// Total: 3 bits = log2(8) would be if done at once. But 2 + 1 = 3. Additive.

(pipeline: FoldPipeline { theorem: 'THM-FOLD-HEAT-HIERARCHY', stages: '2' })
(stage_1_in: StageInput { elements: '4', values: '[10, 20, 30, 40]' })
(fold_1: FoldOperator { type: 'pairwise-merge', inputs: '4', outputs: '2', heat: '2' })
(stage_1_out: StageOutput { elements: '2', values: '[15, 35]' })
(fold_2: FoldOperator { type: 'binary-merge', inputs: '2', outputs: '1', heat: '1' })
(stage_2_out: StageOutput { elements: '1', values: '[25]' })
(additivity: Invariant { claim: 'total heat = heat_1 + heat_2', heat_1: '2', heat_2: '1', total: '3' })
(result: Result { theorem: 'sequential-folds-additive-heat' })

(pipeline)-[:PROCESS]->(stage_1_in)
(stage_1_in)-[:FOLD { strategy: 'pairwise-merge' }]->(fold_1)
(fold_1)-[:PROCESS]->(stage_1_out)
(stage_1_out)-[:FOLD { strategy: 'binary-merge' }]->(fold_2)
(fold_2)-[:PROCESS]->(stage_2_out)
(stage_1_out | stage_2_out)-[:RACE { expect: 'heats-computed' }]->(additivity)
(additivity)-[:FOLD { strategy: 'verify-sum' }]->(result)
