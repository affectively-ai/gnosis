(parse:ModuleParse)-[:PROCESS]->(resolve_specs:ModuleResolveImportSpecifiers)
(resolve_specs)-[:PROCESS]->(load_imports:ModuleLoadImports)
(load_imports)-[:PROCESS]->(validate_imports:ModuleValidateImports)
(validate_imports)-[:PROCESS]->(compile:ModuleCompileTopology)
(compile)-[:PROCESS]->(determine_exports:ModuleDetermineExports)
(determine_exports)-[:PROCESS]->(merge:ModuleMergeTopology)
(merge)-[:PROCESS]->(validate_exports:ModuleValidateExports)
(validate_exports)-[:PROCESS]->(assemble:ModuleAssembleModule)
