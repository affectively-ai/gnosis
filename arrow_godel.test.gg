// arrow_godel.test.gg — Native Gnosis witnesses for THM-ARROW-GODEL-CONSCIOUSNESS
//
// These theorem-shaped `.gg` modules cover three deep corollaries:
//   - voting = fold, Arrow impossibility from trilemma
//   - undecidable = permanent void (Godel infinite void)
//   - quale = complement of vented (consciousness as surviving branch)

(test_suite: TestSuite { name: 'arrow-godel-consciousness' })

(arrow_impossibility: Verify { module: './arrow_impossibility.gg', beta1_max: '7' })
(godel_infinite_void: Verify { module: './godel_infinite_void.gg', beta1_max: '7' })
(consciousness_branch: Verify { module: './consciousness_surviving_branch.gg', beta1_max: '7' })

(test_suite)-[:FORK]->(arrow_impossibility | godel_infinite_void | consciousness_branch)

(arrow_impossibility)-[:RACE { expect: 'safe' }]->(arrow_result: Result)
(godel_infinite_void)-[:RACE { expect: 'safe' }]->(godel_result: Result)
(consciousness_branch)-[:RACE { expect: 'safe' }]->(consciousness_result: Result)

(arrow_result | godel_result | consciousness_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
