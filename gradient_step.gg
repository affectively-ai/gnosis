// gradient_step.gg
// Scalar gradient descent update using native differentiable primitives.

(seed:Parameter { value: '2.0' })
(param:Parameter)
(grad:Gradient { value: '1.5' })
(update:GradientStep { learningRate: '0.1', parameterKey: 'param', gradientKey: 'grad' })
(sink:Sink)

(seed)-[:FORK]->(param | grad)
(param | grad)-[:FOLD]->(update)
(update)-[:PROCESS]->(sink)
