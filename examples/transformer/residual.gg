// residual.gg — Residual Connection
//
// The residual IS interference. The skip connection adds the input
// back to the output — constructive interference in the topology.
// This is why transformers can be deep: gradients flow through
// the interference path unchanged.
//
// β₁ = 0 (interference is not superposition — it's composition)

(skip_input: Tensor)
(transformed: Tensor)

(skip_input | transformed)-[:INTERFERE { mode: 'constructive' }]->(residual_out)
